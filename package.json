{
  "name": "kzi-attendance-app",
  "version": "2.0.0",
  "description": "Student Attendance Management System with MySQL",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "dev:full": "concurrently \"node -r ../be/ts-register.js ../be/server-mysql.ts\" \"vite\"",
    "server": "node -r ../be/ts-register.js ../be/server-mysql.ts",
    "build": "node -r ../be/ts-register.js ../be/database/auto-migrate.ts && vite build",
    "build:db": "node -r ../be/ts-register.js ../be/database/auto-migrate.ts",
    "migrate": "node -r ../be/ts-register.js ../be/database/migrate.ts",
    "migrate:safe": "node -r ../be/ts-register.js ../be/database/migrate-safe.ts",
    "backup": "node -r ../be/ts-register.js ../be/database/backup.ts now",
    "backup:list": "node -r ../be/ts-register.js ../be/database/backup.ts list",
    "backup:restore": "node -r ../be/ts-register.js ../be/database/backup.ts restore",
    "build:frontend": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "clsx": "^2.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "firebase": "^12.7.0",
    "jspdf": "^2.5.1",
    "jsqr": "^1.4.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.344.0",
    "mysql2": "^3.9.1",
    "qrcode": "^1.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.1",
    "recharts": "^2.12.0",
    "tailwind-merge": "^2.2.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.19",
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.2.2",
    "vite": "^5.1.4"
  }
}
